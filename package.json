{
  "name": "img-view",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server-build.json && node scripts/write-server-package.cjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently -k -n vite,electron \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && npm run build:server && electron-builder",
    "electron:build:mac": "npm run build && npm run build:server && electron-builder --mac",
    "electron:build:win": "npm run build && npm run build:server && electron-builder --win",
    "electron:build:linux": "npm run build && npm run build:server && electron-builder --linux"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.0",
    "zod": "^3.24.0",
    "lucide-react": "^0.503.0",
    "fastify": "^5.3.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "~5.7.0",
    "vite": "^6.3.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "tsx": "^4.19.0",
    "concurrently": "^9.1.0",
    "wait-on": "^8.0.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "vitest": "^3.1.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "jsdom": "^26.0.0"
  },
  "build": {
    "appId": "com.singzis.imgview",
    "productName": "ImgView",
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.photography",
      "target": ["dmg", "zip"],
      "artifactName": "ImgView-${version}-mac.${ext}"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "ImgView-${version}-win.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "artifactName": "ImgView-${version}-linux.${ext}",
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
